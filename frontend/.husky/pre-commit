#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

repo_root="$(git rev-parse --show-toplevel)"
frontend_dir="$repo_root/frontend"

if [ ! -x "$frontend_dir/node_modules/.bin/lint-staged" ]; then
  echo "frontend dependencies are missing. Run: pnpm --dir frontend install --frozen-lockfile" >&2
  exit 1
fi

cd "$frontend_dir"
pnpm exec lint-staged
